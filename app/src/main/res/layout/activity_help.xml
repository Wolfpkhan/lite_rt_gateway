<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LiteRT Gateway"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverUrlText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API 端点"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• POST /v1/chat/completions - 聊天补全\n• GET /v1/models - 获取可用模型\n• GET /health - 健康检查"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用示例"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文本聊天:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="curl -X POST http://IP:PORT/v1/chat/completions \\\n  -H &quot;Content-Type: application/json&quot; \\\n  -d &apos;{&quot;messages&quot;:[{&quot;role&quot;:&quot;user&quot;,&quot;content&quot;:&quot;Hello&quot;}]}&apos;"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="流式输出:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="curl -X POST http://IP:PORT/v1/chat/completions \\\n  -H &quot;Content-Type: application/json&quot; \\\n  -d &apos;{&quot;messages&quot;:[{&quot;role&quot;:&quot;user&quot;,&quot;content&quot;:&quot;Tell me a story&quot;}],&quot;stream&quot;:true}&apos;"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="多轮对话:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="curl -X POST http://IP:PORT/v1/chat/completions \\\n  -H &quot;Content-Type: application/json&quot; \\\n  -d &apos;{\&quot;messages\&quot;:[{\&quot;role\&quot;:\&quot;user\&quot;,\&quot;content\&quot;:\&quot;My name is Alice\&quot;},{\&quot;role\&quot;:\&quot;assistant\&quot;,\&quot;content\&quot;:\&quot;Hi Alice!\&quot;},{\&quot;role\&quot;:\&quot;user\&quot;,\&quot;content\&quot;:\&quot;What is my name?\&quot;}]}&apos;"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="图像识别:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="curl -X POST http://IP:PORT/v1/chat/completions \\\n  -H &quot;Content-Type: application/json&quot; \\\n  -d &apos;{\&quot;messages\&quot;:[{\&quot;role\&quot;:\&quot;user\&quot;,\&quot;content\&quot;:[{\&quot;type\&quot;:\&quot;text\&quot;,\&quot;text\&quot;:\&quot;描述这张图片\&quot;},{\&quot;type\&quot;:\&quot;image_url\&quot;,\&quot;image_url\&quot;:{\&quot;url\&quot;:\&quot;data:image/png;base64,...\&quot;}}]}]}&apos;"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="音频识别:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="curl -X POST http://IP:PORT/v1/chat/completions \\\n  -H &quot;Content-Type: application/json&quot; \\\n  -d &apos;{\&quot;messages\&quot;:[{\&quot;role\&quot;:\&quot;user\&quot;,\&quot;content\&quot;:[{\&quot;type\&quot;:\&quot;text\&quot;,\&quot;text\&quot;:\&quot;描述这段音频\&quot;},{\&quot;type\&quot;:\&quot;audio\&quot;,\&quot;audio\&quot;:{\&quot;url\&quot;:\&quot;data:audio/mp3;base64,...\&quot;}}]}]}&apos;"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接说明"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• USB调试: adb forward tcp:12345 tcp:PORT\n  然后访问 http://localhost:12345\n• WiFi局域网: 确保手机和电脑在同一网络\n• 服务地址显示在主界面URL处"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>